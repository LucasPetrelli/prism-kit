#!/bin/sh

set -e

if command -v python >/dev/null 2>&1; then
  PYTHON=python
elif command -v python3 >/dev/null 2>&1; then
  PYTHON=python3
else
  echo "python or python3 is required to run the formatting hook." >&2
  exit 1
fi

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

# ── Stage 1: format staged sources ──────────────────────────────────
"$PYTHON" scripts/format.py --staged --git-add

# ── Stage 2: lint staged sources (blocking) ─────────────────────────
# clang-tidy runs on staged .cpp/.hpp files.  Violations (including all
# readability-* checks configured as WarningsAsErrors) block the commit.
if [ -f "build/compile_commands.json" ]; then
  "$PYTHON" scripts/lint.py --staged
else
  echo "[pre-commit] build/compile_commands.json not found — skipping lint."
fi